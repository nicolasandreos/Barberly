generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String    @id @default(uuid())
  name      String
  email     String    @unique
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  bookings  Booking[]
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

model Booking {
  id           String        @id @default(uuid())
  idUser       String
  idBarbershop String
  idService    String
  status       BookingStatus
  startsAt     DateTime
  endsAt       DateTime
  user         User          @relation(fields: [idUser], references: [id], onDelete: Cascade)
  barbershop   Barbershop    @relation(fields: [idBarbershop], references: [id], onDelete: Cascade)
  service      Service       @relation(fields: [idService], references: [id], onDelete: Cascade)
}

model Barbershop {
  id          String    @id @default(uuid())
  name        String
  address     String
  description String
  imageUrl    String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  bookings    Booking[]
  services    Service[]
  phones      Phone[]
}

model Service {
  id           String     @id @default(uuid())
  idBarbershop String
  name         String
  price        Decimal    @db.Decimal(5, 2)
  description  String
  bookings     Booking[]
  barbershop   Barbershop @relation(fields: [idBarbershop], references: [id], onDelete: Cascade)
}

model Phone {
  id           String     @id @default(uuid())
  number       String
  barbershopId String
  barbershop   Barbershop @relation(fields: [barbershopId], references: [id], onDelete: Cascade)
}
